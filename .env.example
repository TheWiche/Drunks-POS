# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas el archivo .env a GitHub.

# URL del proyecto Supabase (reemplaza con tu Project ID)
SUPABASE_URL=https://TU_PROJECT_ID.supabase.co

# Clave anon de Supabase (legacy JWT o nueva publishable key)
SUPABASE_KEY=tu_clave_aqui

# Puerto del servidor (Railway lo inyecta automáticamente)
PORT=8000
